{
  "manifest_version": 3,
  "name": "JS Recon — API Map & Secret Miner",
  "version": "1.1.0",
  "description": "As you browse, mine JavaScript for secrets and endpoints and build a live API map + OpenAPI spec. For authorized recon only.",
  "permissions": ["storage", "unlimitedStorage", "webRequest", "tabs", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["cs.js"], "run_at": "document_idle", "all_frames": true }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "JS Recon",
    "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "icons": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
